<form class="{{cssClass}} stonetop-monster-sheet" autocomplete="off">
	<div class="sheet-wrapper stonetop-monster-container">

		<header class="sheet-header stonetop-sheet-header stonetop-monster-header{{#unless stonetop.editMode}}{{#unless stonetop.hasPortrait}} stonetop-monster-header--no-portrait{{/unless}}{{/unless}}">
			{{#if stonetop.editMode}}
			<img class="stonetop-portrait" src="{{actor.img}}" data-edit="img"
			     title="{{actor.name}}" alt="{{actor.name}}">
			{{else}}{{#if stonetop.hasPortrait}}
			<img class="stonetop-portrait" src="{{stonetop.displayImg}}"
			     title="{{actor.name}}" alt="{{actor.name}}">
			{{/if}}{{/if}}
			<div class="sheet-header__fields">
				<div class="stonetop-monster-header-row">
					{{#if stonetop.editMode}}
					<input class="input--title stonetop-name-field" name="name" type="text"
					       value="{{actor.name}}" placeholder='{{localize "stonetop.monster.namePlaceholder"}}'>
					{{else}}
					<span class="input--title stonetop-header-locked stonetop-name-field">{{actor.name}}</span>
					{{/if}}

					{{!-- HP & Armor — boxed vital cells, vertically centered on the name --}}
					<div class="sheet-attributes-top stonetop-monster-statbar stonetop-monster-header-statbar">
						<div class="cell--attributes-top flexrow">
							<div class="cell cell--Resource cell--attr-hp">
								<div class="stonetop-vital-inner">
									<label class="cell__title">{{localize "stonetop.monster.hitPoints"}}</label>
									<div class="cell__resource">
										<span class="cell__value">
											<input class="attr-value" type="number"
											       name="system.attributes.hp.value"
											       value="{{system.attributes.hp.value}}" min="0">
										</span>
										<span class="cell__separator">/</span>
										<span class="cell__max">
											<input class="attr-max" type="number"
											       name="system.attributes.hp.max"
											       value="{{system.attributes.hp.max}}" min="0">
										</span>
									</div>
								</div>
							</div>

							<div class="cell cell--Number cell--attr-armor">
								<div class="stonetop-vital-inner">
									<label class="cell__title">{{localize "stonetop.monster.armor"}}</label>
									<input class="attr-value" type="number"
									       name="system.attributes.armor.value"
									       value="{{system.attributes.armor.value}}" min="0">
								</div>
							</div>
						</div>
					</div>
				</div>

				<div class="stonetop-monster-subtitle">
					{{#if stonetop.editMode}}
					<textarea name="system.concept"
					          placeholder='{{localize "stonetop.monster.conceptPlaceholder"}}'>{{system.concept}}</textarea>
					{{else}}
					<p>{{system.concept}}</p>
					{{/if}}
				</div>
			</div>
		</header>

		<section class="sheet-top stonetop-monster-top">
			<div class="stonetop-monster-stat-block">
				<div class="stonetop-monster-stat-line">
					<strong class="stonetop-monster-stat-key">{{localize "stonetop.monster.damage"}}</strong>
					{{#if stonetop.editMode}}
					<input class="stonetop-monster-stat-input" type="text"
					       name="system.attributes.damage.value" value="{{system.attributes.damage.value}}"
					       placeholder="claws, rocks, choking d6 (hand)">
					<input class="stonetop-monster-stat-input stonetop-monster-damage-formula-input" type="text"
					       name="system.attributes.damage.rollFormula" value="{{system.attributes.damage.rollFormula}}"
					       title="Rollable dice formula (e.g. d6, 1d8+2)" placeholder="d6">
					{{else}}
					<span>{{system.attributes.damage.value}}</span>
					{{/if}}
					{{#if system.attributes.damage.rollFormula}}
					<a class="stonetop-monster-damage-roll" title="Roll damage ({{system.attributes.damage.rollFormula}})">
						<i class="fas fa-dice-d6"></i>
					</a>
					{{/if}}
				</div>
				<div class="stonetop-monster-stat-line">
					<strong class="stonetop-monster-stat-key">{{localize "stonetop.monster.instinct"}}</strong>
					{{#if stonetop.editMode}}
					<input class="stonetop-monster-stat-input" type="text"
					       name="system.attributes.instinct.value" value="{{system.attributes.instinct.value}}"
					       placeholder="to...">
					{{else}}
					<span>{{system.attributes.instinct.value}}</span>
					{{/if}}
				</div>
				<div class="stonetop-monster-stat-line">
					<strong class="stonetop-monster-stat-key">{{localize "stonetop.monster.creatureType"}}</strong>
					{{#if stonetop.editMode}}
					<select class="stonetop-monster-stat-input stonetop-monster-org-select" name="system.creatureType">
						{{selectOptions stonetop.creatureTypeChoices selected=system.creatureType blank=""}}
					</select>
					{{else}}
					<span>{{stonetop.creatureTypeLabel}}</span>
					{{/if}}
				</div>
				<div class="stonetop-monster-stat-line stonetop-monster-stat-line--traits">
					{{#if stonetop.editMode}}
					<span class="stonetop-monster-stat-key">{{localize "stonetop.monster.organization"}}</span>
					<select class="stonetop-monster-stat-input stonetop-monster-org-select" name="system.organization">
						{{selectOptions stonetop.organizationChoices selected=system.organization localize=true blank=""}}
					</select>
					<span class="stonetop-monster-stat-sep"> · </span>
					<span class="stonetop-monster-stat-key">{{localize "stonetop.monster.size"}}</span>
					<input class="stonetop-monster-stat-input" type="text"
					       name="system.size" value="{{system.size}}"
					       placeholder="tiny, small, large, huge">
					<span class="stonetop-monster-stat-sep"> · </span>
					<span class="stonetop-monster-stat-key">{{localize "stonetop.monster.tags"}}</span>
					<input class="stonetop-monster-stat-input" type="text"
					       name="system.tags" value="{{system.tags}}"
					       placeholder="hoarder, cautious, stealthy...">
					<a class="stonetop-monster-reset-defaults" title='{{localize "stonetop.monster.resetDefaults"}}'>
						<i class="fas fa-rotate-left"></i>
					</a>
					{{else}}
					{{#if stonetop.organizationLabel}}<span>{{localize stonetop.organizationLabel}}</span>{{/if}}
					{{#if system.size}}{{#if stonetop.organizationLabel}}<span class="stonetop-monster-stat-sep"> · </span>{{/if}}<span>{{system.size}}</span>{{/if}}
					{{#if stonetop.displayTags}}{{#if (or stonetop.organizationLabel system.size)}}<span class="stonetop-monster-stat-sep"> · </span>{{/if}}<span>{{stonetop.displayTags}}</span>{{/if}}
					{{/if}}
				</div>
			</div>

			{{#if stonetop.entryLink}}
			<a class="stonetop-monster-entry-link" data-entry-uuid="{{system.entry}}">
				<i class="fas fa-book"></i> {{stonetop.entryLink.name}}
			</a>
			{{/if}}
		</section>

		<section class="sheet-main flexcol stonetop-monster-main">
			<section class="sheet-body stonetop-monster-body">

				<section class="stonetop-monster-field stonetop-monster-field--full">
					{{> "stonetop.section-heading" title=(localize "stonetop.monster.qualities")}}
					{{#if stonetop.editMode}}
					<prose-mirror class="stonetop-monster-rich-editor"
					              data-field="qualities" toggled>{{{stonetop.enrichedQualities}}}</prose-mirror>
					{{else}}
					<div class="stonetop-monster-readonly-text stonetop-monster-rich-text">{{{stonetop.enrichedQualities}}}</div>
					{{/if}}
				</section>

				{{!-- Moves --}}
				<section class="stonetop-monster-field stonetop-monster-field--full">
					{{> "stonetop.section-heading" title=(localize "stonetop.monster.tabs.moves")}}
					<ul class="stonetop-monster-moves-list">
						{{#each monsterMoves}}
						<li class="stonetop-monster-move-item" data-item-id="{{id}}">
							<div class="stonetop-monster-move-controls">
								{{#if ../stonetop.editMode}}
								<a class="stonetop-monster-delete-move" title='{{localize "stonetop.monster.deleteMove"}}'>
									<i class="fas fa-trash"></i>
								</a>
								{{/if}}
								{{#if system.rollFormula}}
								<a class="stonetop-monster-move-roll" title="Roll {{system.rollFormula}}">
									<i class="fas fa-dice-d6"></i>
								</a>
								{{/if}}
							</div>
							<div class="stonetop-monster-move-body">
								{{#if ../stonetop.editMode}}
								<a class="stonetop-monster-move-name">{{name}}</a>
								{{else}}
								<span class="stonetop-monster-move-name">{{name}}</span>
								{{/if}}
								{{#if system.description}}
								<div class="stonetop-monster-move-description">{{{boldMissText system.description}}}</div>
								{{/if}}
							</div>
						</li>
						{{else}}
						<li class="stonetop-monster-moves-empty">{{localize "stonetop.monster.noMoves"}}</li>
						{{/each}}
					</ul>
					{{#if stonetop.editMode}}
					<div class="stonetop-monster-add-controls">
						<a class="stonetop-monster-add-move">
							<i class="fas fa-plus"></i> {{localize "stonetop.monster.addMove"}}
						</a>
					</div>
					{{/if}}
				</section>

				{{!-- Combat: organization budget + group abstraction helper --}}
				<section class="stonetop-monster-field stonetop-monster-field--full stonetop-monster-combat">
					{{> "stonetop.section-heading" title=(localize "stonetop.monster.combat")}}
					<div class="stonetop-monster-combat-grid">
						<div class="stonetop-monster-combat-budget">
							{{#if stonetop.organizationLabel}}
							<span class="stonetop-monster-combat-pill">{{localize stonetop.organizationLabel}}</span>
							<span class="stonetop-monster-combat-note">{{stonetop.budgetNote}}</span>
							{{else}}
							<span class="stonetop-monster-combat-note">{{localize "stonetop.monster.individual"}}</span>
							{{/if}}
						</div>

						<label class="stonetop-monster-count-field">
							<span>{{localize "stonetop.monster.count"}}</span>
							<input type="number" min="1" name="system.count"
							       value="{{system.count}}" class="stonetop-monster-count-input">
						</label>
					</div>

					{{#if stonetop.abstracted}}
					<div class="stonetop-monster-abstraction">
						<p class="stonetop-monster-abstraction-hint">{{localize "stonetop.monster.abstractionHint"}}</p>
						<div class="stonetop-monster-outnumber">
							<label>
								<span>{{localize "stonetop.monster.outnumberBonus"}}</span>
								<span class="stonetop-monster-outnumber-vs">vs</span>
								<input type="number" min="1" class="stonetop-monster-outnumber-foes"
								       placeholder="# foes" value="">
							</label>
							<span class="stonetop-monster-outnumber-result" data-count="{{system.count}}">+0 / +0</span>
						</div>
						<p class="stonetop-monster-abstraction-casualty">
							{{localize "stonetop.monster.casualtyThreshold"}}
							<span class="stonetop-monster-casualty-detail">{{stonetop.casualtyNote}}</span>
						</p>
					</div>
					{{/if}}
				</section>

				{{!-- Notes --}}
				<section class="stonetop-monster-field stonetop-monster-field--full">
					{{> "stonetop.section-heading" title=(localize "stonetop.monster.notes")}}
					{{#if stonetop.editMode}}
					<textarea name="system.notes">{{system.notes}}</textarea>
					{{else}}
					<div class="stonetop-monster-readonly-text">{{system.notes}}</div>
					{{/if}}
				</section>

			</section>
		</section>
	</div>
</form>
