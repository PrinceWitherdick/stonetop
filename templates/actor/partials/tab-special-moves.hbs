<div class="tab stonetop-special-moves" data-group="primary" data-tab="special-moves">

	{{> "stonetop.section-heading" title=(localize "stonetop.sheet.tabs.specialMoves")}}

	<div class="stonetop-special-move-grid">

		<div class="stonetop-special-move-card">
			<h3 class="stonetop-special-move-name">{{localize "stonetop.specialMoves.burnBrightly.title"}}</h3>
			<p class="stonetop-special-move-summary">{{{localize "stonetop.specialMoves.burnBrightly.description"}}}</p>
			<p class="stonetop-special-move-locked-hint">
				<i class="fas fa-comment-dots"></i>
				{{localize "stonetop.specialMoves.burnBrightly.promptNote"}}
			</p>
		</div>

		<div class="stonetop-special-move-card">
			<h3 class="stonetop-special-move-name">{{localize "stonetop.specialMoves.outfit.title"}}</h3>
			<p class="stonetop-special-move-summary">{{{localize "stonetop.specialMoves.outfit.summary"}}}</p>
			<button type="button" class="stonetop-outfit-open-btn">
				<i class="fas fa-suitcase"></i>
				{{localize "stonetop.specialMoves.outfit.button"}}
			</button>
		</div>

		<div class="stonetop-special-move-card{{#unless stonetop.isDying}} is-locked{{/unless}}">
			<h3 class="stonetop-special-move-name">{{localize "stonetop.specialMoves.deathsDoor.title"}}</h3>
			<p class="stonetop-special-move-summary">{{{localize "stonetop.specialMoves.deathsDoor.summary"}}}</p>
			{{#unless stonetop.isDying}}
			<p class="stonetop-special-move-locked-hint">
				<i class="fas fa-lock"></i>
				{{localize "stonetop.specialMoves.deathsDoor.lockedHint"}}
			</p>
			{{/unless}}
			<button type="button" class="stonetop-deathsdoor-open-btn"
				{{#unless stonetop.isDying}}disabled{{/unless}}>
				<i class="fas fa-door-open"></i>
				{{localize "stonetop.specialMoves.deathsDoor.button"}}
			</button>
		</div>

		<div class="stonetop-special-move-card{{#unless stonetop.canLevelUp}} is-locked{{/unless}}">
			<h3 class="stonetop-special-move-name">{{localize "stonetop.specialMoves.levelUp.title"}}</h3>
			<p class="stonetop-special-move-summary">{{{localize "stonetop.specialMoves.levelUp.summary"}}}</p>
			{{#unless stonetop.canLevelUp}}
			<p class="stonetop-special-move-locked-hint">
				<i class="fas fa-lock"></i>
				{{{localize "stonetop.specialMoves.levelUp.lockedHint"}}}
			</p>
			{{/unless}}
			<button type="button" class="stonetop-levelup-open-btn"
				{{#unless stonetop.canLevelUp}}disabled{{/unless}}>
				<i class="fas fa-arrow-circle-up"></i>
				{{localize "stonetop.specialMoves.levelUp.button"}}
			</button>
		</div>

		{{#if stonetop.hasFollowers}}
		<div class="stonetop-special-move-card">
			<h3 class="stonetop-special-move-name">Order Followers</h3>
			<p class="stonetop-special-move-summary">When you <strong><em>direct them to make a move and they do so</em></strong>, roll +1 instead of +STAT if any of their tags apply (or +2 if they're also <em>exceptional</em>). If no tags apply, roll +0. If any of their tags would get in the way, roll with disadvantage.</p>
		</div>

		<div class="stonetop-special-move-card">
			<h3 class="stonetop-special-move-name">Strengthen Your Bond</h3>
			<p class="stonetop-special-move-summary">When you <strong><em>pay their cost</em></strong> and you haven't done so recently, they hold +1 Loyalty (max 3). Spend Loyalty 1-for-1 to have them: overcome their fear; resist their instinct/tags/traits; or do something they don't want to (as long as it's not abhorrent or suicidal).</p>
		</div>
		{{/if}}

	</div>

</div>
