<div class="tab details{{#unless stonetop.editMode}} stonetop-readonly{{/unless}}" data-group="primary" data-tab="details">

		{{#each stonetop.inventory.possessions.items}}
		{{#if (and detailsSection checked choiceGroups)}}
		<div class="details-section">
			{{> "stonetop.section-heading" title=detailsSection}}
			{{#if description}}<div class="stonetop-item-description">{{{description}}}</div>{{/if}}
			{{> "stonetop.possession-choice-groups" scope="details-"}}
		</div>
		{{/if}}
		{{/each}}

		{{> "stonetop.lore-section" lore=stonetop.playbook.lore}}

		{{#if stonetop.playbook.background.options.length}}
		<div class="details-section">
			{{#if stonetop.editMode}}
			{{> "stonetop.section-heading" title=(localize "stonetop.character.selection.background.label") note=(localize "stonetop.character.selection.chooseOne")}}
			{{#each stonetop.playbook.background.options}}
			<label class="stonetop-item{{#if selected}} is-checked{{/if}}">
				<div class="stonetop-item-header">
					<input type="radio" class="stonetop-item-check" name="stonetop-background"
					       value="{{slug}}"{{#if selected}} checked{{/if}}>
					<strong class="stonetop-item-name">{{label}}</strong>
				</div>
				{{#if description}}
				<div class="stonetop-item-description stonetop-bg-description">{{{description}}}</div>
				{{/if}}
			</label>
			{{#if (and selected choices)}}
			<div class="stonetop-bg-choices">
				<p class="stonetop-bg-choices-label">{{choices.label}} (choose {{choices.countLabel}})</p>
				{{#each choices.options}}
				<label class="stonetop-bg-choice-option">
					<input type="checkbox" class="stonetop-item-check stonetop-bg-choice"
					       data-slug="{{slug}}"
					       {{#if checked}}checked{{/if}}>
					{{label}}
				</label>
				{{/each}}
			</div>
			{{/if}}
			{{/each}}
			{{else}}
			{{#if stonetop.playbook.background.selected}}
			{{> "stonetop.section-heading" title=(localize "stonetop.character.selection.background.label")}}
			{{#each stonetop.playbook.background.options}}
			{{#if selected}}
			<div class="stonetop-item is-checked stonetop-bg-readonly">
				<div class="stonetop-item-header">
					<strong class="stonetop-item-name">{{label}}</strong>
				</div>
				{{#if description}}
				<div class="stonetop-item-description stonetop-bg-description">{{{description}}}</div>
				{{/if}}
			</div>
			{{#if choices}}
			<div class="stonetop-bg-choices">
				<p class="stonetop-bg-choices-label">{{choices.label}}</p>
				{{#each choices.options}}
				{{#if checked}}<p class="stonetop-bg-choice-readonly">{{label}}</p>{{/if}}
				{{/each}}
			</div>
			{{/if}}
			{{#if setupTexts.length}}
			<div class="stonetop-bg-choices">
				{{#each setupTexts}}
				{{#if value}}
				<p class="stonetop-bg-choices-label">{{label}}</p>
				<p class="stonetop-bg-choice-readonly">{{value}}</p>
				{{/if}}
				{{/each}}
			</div>
			{{/if}}
			{{#if setupResources.length}}
			<div class="stonetop-bg-choices stonetop-bg-resources">
				{{#each setupResources}}
				<div class="stonetop-bg-resource-row">
					<p class="stonetop-bg-choices-label">{{label}}</p>
					<span class="stonetop-item-resources">
						{{#each checks}}
						<button type="button"
						        class="stonetop-item-resource-check stonetop-bg-resource-check{{#if checked}} is-checked{{/if}}"
						        data-key="{{../key}}"
						        data-index="{{index}}"></button>
						{{/each}}
					</span>
				</div>
				{{/each}}
			</div>
			{{/if}}
			{{/if}}
			{{/each}}
			{{/if}}
			{{/if}}
		</div>
		{{/if}}

		{{#if (and stonetop.playbook stonetop.editMode)}}
		<div class="details-section">
			{{> "stonetop.section-heading" title=(localize "stonetop.character.selection.instinct.label") note=(localize "stonetop.character.selection.chooseOne")}}
			<input type="text" class="stonetop-instinct-custom"
			       value="{{stonetop.playbook.instinct.selected}}"
			       placeholder="{{localize "stonetop.character.selection.instinct.customPlaceholder"}}">
			{{#if stonetop.playbook.instinct.options.length}}
			<div class="stonetop-instinct-options">
				{{#each stonetop.playbook.instinct.options}}
				<label class="stonetop-item{{#if selected}} is-checked{{/if}}">
					<div class="stonetop-item-header">
						<input type="radio" class="stonetop-item-check" name="stonetop-instinct"
						       value="{{value}}"{{#if selected}} checked{{/if}}>
						<strong class="stonetop-item-name">{{word}}</strong>
					</div>
					<div class="stonetop-item-description">{{description}}</div>
				</label>
				{{/each}}
			</div>
			{{/if}}
		</div>
		{{/if}}

		{{#if (and stonetop.playbook stonetop.editMode stonetop.playbook.appearance.options.length)}}
		<div class="details-section">
			{{> "stonetop.section-heading" title=(localize "stonetop.character.selection.appearance.label") note=(localize "stonetop.character.selection.appearance.instruction")}}
			{{#each stonetop.playbook.appearance.options}}
			<div class="stonetop-appearance-row">
				{{#each options}}
				<label class="stonetop-item stonetop-appearance-option{{#if selected}} is-checked{{/if}}">
					<div class="stonetop-item-header">
						<input type="radio" class="stonetop-item-check stonetop-appearance-radio"
						       name="stonetop-appearance-{{../lineIdx}}"
						       data-line="{{../lineIdx}}"
						       value="{{value}}"{{#if selected}} checked{{/if}}>
						<strong class="stonetop-item-name">{{value}}</strong>
					</div>
				</label>
				{{/each}}
			</div>
			{{/each}}
		</div>
		{{/if}}

		{{#if stonetop.playbook.origin.options.length}}
		<div class="details-section">
			{{#if stonetop.editMode}}
			{{> "stonetop.section-heading" title=(localize "stonetop.character.selection.origin.label") note=(localize "stonetop.character.selection.origin.instruction")}}
			{{#each stonetop.playbook.origin.options}}
			<div class="stonetop-item stonetop-origin-option{{#if selected}} is-checked selected{{/if}}">
				<label class="stonetop-item-header stonetop-origin-region">
					<input type="radio" class="stonetop-item-check" name="stonetop-origin"
					       value="{{region}}"{{#if selected}} checked{{/if}}>
					<strong class="stonetop-item-name">{{region}}</strong>
				</label>
				<div class="stonetop-origin-names">
					{{#each names}}
					<label class="stonetop-origin-name-label{{#if checked}} is-checked{{/if}}">
						<input type="radio" class="stonetop-origin-name-check"
						       name="stonetop-origin-name-{{../region}}"
						       value="{{name}}"
						       {{#if checked}}checked{{/if}}>
						{{name}}
					</label>
					{{/each}}
				</div>
			</div>
			{{/each}}
			{{else}}
			{{#if stonetop.playbook.origin.selected}}
			{{> "stonetop.section-heading" title=(localize "stonetop.character.selection.origin.label")}}
			{{#each stonetop.playbook.origin.options}}
			{{#if selected}}
			<div class="stonetop-item is-checked stonetop-origin-readonly">
				<div class="stonetop-item-header">
					<strong class="stonetop-item-name">{{region}}</strong>
				</div>
				{{#if description}}
				<div class="stonetop-origin-description">{{{description}}}</div>
				{{/if}}
			</div>
			{{/if}}
			{{/each}}
			{{/if}}
			{{/if}}
		</div>
		{{/if}}

		{{#if (and stonetop.playbook stonetop.hasIncompleteBackgroundQuestions)}}
		<div class="details-section stonetop-details-onboarding-actions">
			<button type="button" class="stonetop-answer-character-questions-btn" data-onboarding-start="first-incomplete">
				<i class="fas fa-question-circle" aria-hidden="true"></i>
				{{localize "stonetop.newCharacter.answerQuestionsButtonLabel"}}
			</button>
		</div>
		{{/if}}

</div>
