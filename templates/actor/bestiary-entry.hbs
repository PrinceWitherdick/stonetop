<form class="{{cssClass}} stonetop-bestiary-sheet" autocomplete="off">
	<div class="sheet-wrapper stonetop-bestiary-container">

		<header class="sheet-header stonetop-sheet-header stonetop-bestiary-header{{#unless stonetop.editMode}}{{#unless stonetop.hasPortrait}} stonetop-bestiary-header--no-portrait{{/unless}}{{/unless}}">
			{{#if stonetop.editMode}}
			<img class="stonetop-portrait" src="{{actor.img}}" data-edit="img"
			     title="{{actor.name}}" alt="{{actor.name}}">
			{{else}}{{#if stonetop.hasPortrait}}
			<img class="stonetop-portrait" src="{{actor.img}}"
			     title="{{actor.name}}" alt="{{actor.name}}">
			{{/if}}{{/if}}
			<div class="sheet-header__fields">
				{{#if stonetop.editMode}}
				<input class="input--title stonetop-name-field" name="name" type="text"
				       value="{{actor.name}}" placeholder='{{localize "stonetop.bestiary.namePlaceholder"}}'>
				{{else}}
				<span class="input--title stonetop-header-locked stonetop-name-field">{{actor.name}}</span>
				{{/if}}
				<div class="stonetop-monster-subtitle">
					{{#if stonetop.editMode}}
					<textarea name="system.concept"
					          placeholder='{{localize "stonetop.bestiary.conceptPlaceholder"}}'>{{system.concept}}</textarea>
					{{else}}
					<p>{{system.concept}}</p>
					{{/if}}
				</div>
			</div>
		</header>

		<section class="sheet-main flexcol stonetop-monster-main">
			<nav class="sheet-tabs tabs" data-group="primary">
				<a class="item" data-tab="overview">{{localize "stonetop.bestiary.tabs.overview"}}</a>
				{{#if stonetop.showTab.codex}}<a class="item" data-tab="codex">{{localize "stonetop.bestiary.tabs.codex"}}</a>{{/if}}
				{{#if stonetop.showTab.prep}}<a class="item" data-tab="prep">{{localize "stonetop.bestiary.tabs.prep"}}</a>{{/if}}
				{{#if stonetop.showTab.discoveries}}<a class="item" data-tab="discoveries">{{localize "stonetop.bestiary.tabs.discoveries"}}</a>{{/if}}
				{{#if stonetop.showTab.statBlocks}}<a class="item" data-tab="statBlocks">{{localize "stonetop.bestiary.tabs.statBlocks"}}</a>{{/if}}
				{{#if stonetop.showTab.notes}}<a class="item" data-tab="notes">{{localize "stonetop.bestiary.tabs.notes"}}</a>{{/if}}
			</nav>

			<section class="sheet-body stonetop-monster-body">

				{{!-- OVERVIEW --}}
				<div class="tab" data-tab="overview">
					<div class="stonetop-monster-grid">
						{{#if stonetop.show.description}}
						<section class="stonetop-monster-field stonetop-monster-field--full">
							{{> "stonetop.section-heading" title=(localize "stonetop.bestiary.description")}}
							{{#if stonetop.editMode}}
							<prose-mirror class="stonetop-entry-rich-editor stonetop-monster-rich-editor--full"
							              data-field="description" toggled>{{{stonetop.enrichedDescription}}}</prose-mirror>
							{{else}}
							<div class="stonetop-monster-readonly-text stonetop-monster-rich-text">{{{stonetop.enrichedDescription}}}</div>
							{{/if}}
						</section>
						{{/if}}

						{{#if stonetop.show.dangers}}
						<section class="stonetop-monster-field">
							{{> "stonetop.section-heading" title=(localize "stonetop.bestiary.dangers")}}
							{{#if stonetop.editMode}}
							<prose-mirror class="stonetop-entry-rich-editor"
							              data-field="dangers" toggled>{{{stonetop.enrichedDangers}}}</prose-mirror>
							{{else}}
							<div class="stonetop-monster-readonly-text stonetop-monster-rich-text stonetop-dangers-text">{{{stonetop.enrichedDangers}}}</div>
							{{/if}}
						</section>
						{{/if}}

						{{#if stonetop.show.nests}}
						<section class="stonetop-monster-field">
							{{> "stonetop.section-heading" title=(localize "stonetop.bestiary.nests")}}
							{{#if stonetop.editMode}}
							<prose-mirror class="stonetop-entry-rich-editor"
							              data-field="nests" toggled>{{{stonetop.enrichedNests}}}</prose-mirror>
							{{else}}
							<div class="stonetop-monster-readonly-text stonetop-monster-rich-text">{{{stonetop.enrichedNests}}}</div>
							{{/if}}
						</section>
						{{/if}}
					</div>
				</div>

				{{!-- CODEX: Questions & Lore (prompt + answer pairs) --}}
				<div class="tab" data-tab="codex">
					<div class="stonetop-monster-grid">
						{{#each stonetop.qaSections}}
						{{#if show}}
						<section class="stonetop-monster-field stonetop-monster-field--full stonetop-entry-qa-section"
						         data-qa-field="{{key}}">
							{{> "stonetop.section-heading" title=(localize label)}}
							<ul class="stonetop-entry-qa-list">
								{{#each pairs}}
								<li class="stonetop-entry-qa-row" data-qa-index="{{@index}}">
									{{#if @root.stonetop.editMode}}
									<div class="stonetop-entry-qa-edit">
										<input type="text" class="stonetop-entry-qa-input stonetop-entry-qa-prompt"
										       value="{{prompt}}" placeholder='{{localize "stonetop.bestiary.questionPlaceholder"}}'>
										<textarea class="stonetop-entry-qa-input stonetop-entry-qa-answer"
										          placeholder='{{localize "stonetop.bestiary.answerPlaceholder"}}'>{{answer}}</textarea>
										<a class="stonetop-entry-remove-qa" title="Remove"><i class="fas fa-trash"></i></a>
									</div>
									{{else}}
									<div class="stonetop-entry-qa-read">
										{{#if lead}}<p class="stonetop-entry-qa-lead-text">{{lead}}</p>{{/if}}
										<p class="stonetop-entry-qa-prompt-text">{{{promptHtml}}}</p>
										{{#if answer}}<p class="stonetop-entry-qa-answer-text">{{{answerHtml}}}</p>{{/if}}
									</div>
									{{/if}}
								</li>
								{{else}}
								<li class="stonetop-monster-line stonetop-monster-line--empty">{{localize "stonetop.bestiary.noLines"}}</li>
								{{/each}}
							</ul>
							{{#if @root.stonetop.editMode}}
							<button type="button" class="stonetop-entry-add-qa" data-field="{{key}}">
								<i class="fas fa-plus"></i> {{localize "stonetop.bestiary.addQuestion"}}
							</button>
							{{/if}}
						</section>
						{{/if}}
						{{/each}}
					</div>
				</div>

				{{!-- PREP: hooks, origins --}}
				<div class="tab" data-tab="prep">
					<div class="stonetop-monster-grid">
						{{#each stonetop.prepLineSections}}
						{{#if show}}
						<section class="stonetop-monster-field stonetop-monster-line-section" data-line-field="{{key}}">
							{{> "stonetop.section-heading" title=(localize label)}}
							{{> "stonetop.bestiary-line-list" this}}
						</section>
						{{/if}}
						{{/each}}
					</div>
				</div>

				{{!-- DISCOVERIES: sub-headed groups (heading + body + bullets) --}}
				<div class="tab" data-tab="discoveries">
					<div class="stonetop-monster-grid">
						<section class="stonetop-monster-field stonetop-monster-field--full stonetop-discovery-section"
						         data-discovery-field="discoveries">
							{{#each stonetop.discoveryGroups}}
							{{#if @root.stonetop.editMode}}
							<div class="stonetop-discovery-edit" data-discovery-index="{{@index}}">
								<input type="text" class="stonetop-discovery-input stonetop-discovery-heading-input"
								       value="{{heading}}" placeholder='{{localize "stonetop.bestiary.discoveryHeadingPlaceholder"}}'>
								<textarea class="stonetop-discovery-input stonetop-discovery-body-input"
								          placeholder='{{localize "stonetop.bestiary.discoveryBodyPlaceholder"}}'>{{body}}</textarea>
								<textarea class="stonetop-discovery-input stonetop-discovery-items-input"
								          placeholder='{{localize "stonetop.bestiary.discoveryItemsPlaceholder"}}'>{{itemsText}}</textarea>
								<a class="stonetop-discovery-remove-group" title="Remove"><i class="fas fa-trash"></i></a>
							</div>
							{{else}}
							<div class="stonetop-discovery-group">
								{{#if heading}}{{> "stonetop.section-heading" title=heading}}{{/if}}
								{{#if bodyHtml}}<p class="stonetop-discovery-body">{{{bodyHtml}}}</p>{{/if}}
								{{#if items.length}}
								<ul class="stonetop-monster-line-list">
									{{#each items}}
									<li class="stonetop-monster-line"><span>{{{html}}}</span></li>
									{{/each}}
								</ul>
								{{/if}}
							</div>
							{{/if}}
							{{/each}}
							{{#if stonetop.editMode}}
							<button type="button" class="stonetop-discovery-add-group">
								<i class="fas fa-plus"></i> {{localize "stonetop.bestiary.addDiscovery"}}
							</button>
							{{/if}}
						</section>
					</div>
				</div>

				{{!-- STAT BLOCKS --}}
				<div class="tab" data-tab="statBlocks">
					<ul class="stonetop-entry-statblock-list">
						{{#each stonetop.statBlocks}}
						<li class="stonetop-entry-statblock" data-statblock-uuid="{{uuid}}">
							{{#if hasImg}}
							<img class="stonetop-entry-statblock-img" src="{{img}}" alt="{{name}}">
							{{/if}}
							<div class="stonetop-entry-statblock-body">
								<a class="stonetop-entry-open-statblock stonetop-entry-statblock-name">{{name}}</a>
								<span class="stonetop-entry-statblock-meta">
									{{#if organization}}{{organization}} · {{/if}}HP {{hpValue}}/{{hpMax}}
								</span>
							</div>
							<div class="stonetop-entry-statblock-controls">
								<a class="stonetop-entry-open-statblock" title='{{localize "stonetop.bestiary.openStatBlock"}}'><i class="fas fa-up-right-from-square"></i></a>
								{{#if @root.stonetop.editMode}}
								<a class="stonetop-entry-unlink-statblock" title='{{localize "stonetop.bestiary.removeStatBlock"}}'><i class="fas fa-link-slash"></i></a>
								{{/if}}
							</div>
						</li>
						{{else}}
						<li class="stonetop-monster-line stonetop-monster-line--empty">{{localize "stonetop.bestiary.noStatBlocks"}}</li>
						{{/each}}
					</ul>
					{{#if stonetop.editMode}}
					<div class="stonetop-monster-add-controls">
						<a class="stonetop-entry-create-statblock"><i class="fas fa-plus"></i> {{localize "stonetop.bestiary.addStatBlock"}}</a>
						<a class="stonetop-entry-link-statblock"><i class="fas fa-link"></i> {{localize "stonetop.bestiary.linkStatBlock"}}</a>
					</div>
					{{/if}}
				</div>

				{{!-- NOTES --}}
				<div class="tab" data-tab="notes">
					<section class="stonetop-monster-field stonetop-monster-field--full">
						{{> "stonetop.section-heading" title=(localize "stonetop.bestiary.notes")}}
						{{#if stonetop.editMode}}
						<textarea name="system.notes">{{system.notes}}</textarea>
						{{else}}
						<div class="stonetop-monster-readonly-text">{{system.notes}}</div>
						{{/if}}
					</section>
				</div>

			</section>
		</section>
	</div>
</form>
