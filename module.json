{
    "$schema":  "https://json.schemastore.org/foundryvtt-module-manifest.json",
    "id":  "stonetop",
    "title":  "Stonetop",
    "description":  "An unofficial module for playing Stonetop in Foundry VTT.",
    "version":  "0.7.6",
    "compatibility":  {
                          "minimum":  "12",
                          "verified":  "13"
                      },
    "relationships":  {
                          "systems":  [
                                          {
                                              "id":  "pbta",
                                              "type":  "system",
                                              "compatibility":  {
                                                                    "verified":  "1.1.1"
                                                                }
                                          }
                                      ]
                      },
    "authors":  [
                    {
                        "name":  "aMediocerDad"
                    },
                    {
                        "name":  "taylor-nightingale"
                    },
                    {
                        "name":  "Dice-Goblin-Click-Clack"
                    },
                    {
                        "name":  "PrinceWitherdick"
                    }
                ],
    "url":  "https://github.com/PrinceWitherdick/stonetop",
    "manifest":  "https://github.com/PrinceWitherdick/stonetop/releases/latest/download/module.json",
    "download":  "https://github.com/PrinceWitherdick/stonetop/releases/download/0.7.6/stonetop.zip",
    "license":  "LICENSE",
    "readme":  "README.md",
    "bugs":  "https://github.com/PrinceWitherdick/stonetop/issues",
    "changelog":  "https://github.com/PrinceWitherdick/stonetop/releases",
    "flags":  {
                  "hotReload":  {
                                    "extensions":  [
                                                       "css",
                                                       "js",
                                                       "hbs",
                                                       "json"
                                                   ],
                                    "paths":  [
                                                  "stonetop.js",
                                                  "module",
                                                  "styles",
                                                  "languages",
                                                  "templates"
                                              ]
                                }
              },
    "esmodules":  [
                      "stonetop.js"
                  ],
    "styles":  [
                   "styles/stonetop.css"
               ],
    "languages":  [
                      {
                          "lang":  "en",
                          "name":  "English",
                          "path":  "languages/en.json"
                      }
                  ],
    "packs":  [
                  {
                      "name":  "stonetop-items",
                      "label":  "Stonetop Items",
                      "path":  "packs/stonetop-items",
                      "type":  "Item",
                      "system":  "pbta"
                  },
                  {
                      "name":  "stonetop-journals",
                      "label":  "Stonetop Journals",
                      "path":  "packs/stonetop-journals",
                      "type":  "JournalEntry"
                  }
              ]
}
